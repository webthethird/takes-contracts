# RPC endpoints (used by foundry.toml)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deploy
DEPLOY_PRIVATE_KEY=0x...
GUARDIAN=0x...
# Optional overrides — defaults are chain-appropriate
# USDC=0x...
# YIELD_SOURCE=0x...   # required on mainnet (Morpho vault); optional on Sepolia (deploys mock if unset)

# Verification
BASESCAN_API_KEY=
